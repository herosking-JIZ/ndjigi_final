# Database
DATABASE_URL="postgresql://ndjigi_user:secure_password_change_me@localhost:5432/ndjigi_db"

# Server
NODE_ENV=development
PORT=8000

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=ndjigi
KEYCLOAK_CLIENT_ID=ndjigi-backend
KEYCLOAK_CLIENT_SECRET=your_client_secret_here
# Dedicated admin client (service account) for Keycloak Admin API
KEYCLOAK_ADMIN_CLIENT_ID=ndjigi-backend-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=your_admin_client_secret_here

# JWT (pour rétrocompatibilité temporaire)
JWT_SECRET=your_jwt_secret_key
JWT_REFRESH_SECRET=your_jwt_refresh_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:8081

# Redis (Phase 0+)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# SMS & OTP (Phase 2+)
SMS_PROVIDER=console
ORANGE_SMS_API_KEY=

# Email (optionnel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FRONTEND_URL=http://localhost:3000

# Gestionnaire Invitation System (Phase 1+)
UPLOAD_DIR=./storage/documents
UPLOAD_MAX_SIZE_MB=5
INVITATION_TOKEN_TTL_HOURS=72
SUPPORT_WHATSAPP=+22606768989

# VTC
VTC_DEFAULT_ZONE_ID=
VTC_COMMISSION_RATE=0.25
VTC_MATCHING_RADIUS_KM=25
VTC_MATCHING_MAX_CANDIDATES=15
VTC_MATCHING_OFFER_SECONDS=30
VTC_MATCHING_MAX_MINUTES=10
VTC_POSITION_MAX_AGE_SECONDS=120
VTC_ARRIVAL_RADIUS_METERS=200
VTC_PIN_VALIDITY_MINUTES=30
# Secret aléatoire distinct du JWT en production (32 octets minimum).
VTC_PIN_SECRET=replace_with_a_long_random_secret

# Location de véhicule
LOCATION_COMMISSION_RATE=0.15

# File Upload System (Production-ready)
STORAGE_PROVIDER=local
STORAGE_LOCAL_BASE_DIR=./uploads/storage
UPLOAD_TEMP_DIR=./uploads/temp
USER_QUOTA_BYTES=1073741824
MAX_FILE_SIZE_BYTES=52428800

# DEV-ONLY Seed Configuration (NEVER use in production)
# These credentials are for local development with `npx prisma db seed`
SEED_ADMIN_EMAIL=admin@parkway.bf
SEED_ADMIN_PASSWORD=Admin@2026
SEED_GESTIONNAIRE_EMAIL=gestionnaire.test@parkway.bf
SEED_GESTIONNAIRE_PASSWORD=Gest@2026
